#!/usr/bin/env bash
set -euo pipefail

# SessionStart hook — outputs dynamic project state so Claude knows what's
# configured and what's missing. Only outputs items that need attention.
# Fully configured projects produce no output (zero context waste).
# Runs fast (~20-50ms — just test -f and pruned find calls).
# Git state is NOT reported here — Claude Code injects its own gitStatus snapshot.

output=""

# Pruned marker search: find the first file matching the given -path pattern,
# skipping node_modules/.git at every level. No -mindepth: it would suppress
# the prune at depth 1, leaving the root node_modules/ and .git/ fully walked.
# The -path patterns used here already imply depth >= 2.
find_marker() {
  find . -maxdepth 4 \( -name node_modules -o -name .git \) -prune -o -path "$1" -print -quit 2>/dev/null || true
}

# 1. Check if optimus:init has been run
if [ ! -f .claude/CLAUDE.md ] || [ ! -f .claude/docs/coding-guidelines.md ]; then
  # Multi-repo workspace: init may live in a sub-repo's .claude/, not the workspace root.
  # .optimus-version is uniquely written by /optimus:init, so it's the authoritative marker.
  multi_repo_marker=$(find_marker '*/.claude/.optimus-version')
  if [ -z "$multi_repo_marker" ]; then
    output+="IMPORTANT: This project has not been initialized with the optimus plugin. You MUST mention this to the user in your first response: recommend running \`/optimus:init\` to set up CLAUDE.md, coding guidelines, and auto-format hooks for effective AI-assisted development."$'\n'
  fi
else
  # 2. Check test infrastructure (only relevant if init was done)
  if [ ! -f .claude/docs/testing.md ]; then
    # Check monorepo subprojects too
    has_testing=$(find_marker '*/docs/testing.md')
    if [ -z "$has_testing" ]; then
      output+="[optimus] Testing docs missing. Suggest re-running \`/optimus:init\` to set up test infrastructure."$'\n'
    fi
  fi

fi

# Only output if there's something to report
[ -n "$output" ] && printf '%s' "$output"

exit 0
